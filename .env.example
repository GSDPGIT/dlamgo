# =========================
# DLAMGO Docker 环境变量模板
# =========================
#
# 使用方式：
# 1. 将本文件复制为 .env
# 2. 按需修改下面的配置
# 3. 在仓库根目录执行：
#    docker compose up --build -d

# -------------------------
# 端口映射
# -------------------------

# 后端映射到宿主机的端口
BACKEND_PORT=6365

# 前端映射到宿主机的端口
FRONTEND_PORT=6366

# -------------------------
# 安全配置
# -------------------------

# JWT 签名密钥
# 强烈建议改成你自己的长随机字符串
JWT_SECRET=

# 初始管理员用户名
ADMIN_USERNAME=admin_user

# 初始管理员密码
# 强烈建议手动设置，不要留空
ADMIN_PASSWORD=

# -------------------------
# 跨域配置
# -------------------------

# 允许跨域的来源，多个来源用英文逗号分隔
# 例如：
# CORS_ALLOWED_ORIGINS=https://example.com,https://panel.example.com
#
# 留空时更适合默认反向代理场景
CORS_ALLOWED_ORIGINS=

# -------------------------
# 登录保护
# -------------------------

# 每分钟允许的登录尝试次数
LOGIN_RATE_LIMIT_PER_MINUTE=12
